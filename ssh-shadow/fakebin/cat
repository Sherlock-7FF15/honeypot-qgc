#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_path_map.sh"
VISIBLE_HOST="${HONEYPOT_HOSTNAME:-gcs-shadow}"

if [[ "$#" -eq 1 && "$1" == "/etc/hostname" ]]; then
  echo "$VISIBLE_HOST"
  exit 0
fi

mapped=()
map_shadow_args_into_array mapped "$@"
exec /bin/cat "${mapped[@]}"
