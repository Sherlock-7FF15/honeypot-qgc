#!/usr/bin/env bash
set -e

VISIBLE_HOST="${HONEYPOT_HOSTNAME:-gcs-shadow}"

if [[ "$#" -eq 0 || "${1:-}" == "-s" || "${1:-}" == "--short" || "${1:-}" == "-f" || "${1:-}" == "--fqdn" ]]; then
  echo "$VISIBLE_HOST"
  exit 0
fi

# For set operations or uncommon flags, fall back to system behavior.
exec /bin/hostname "$@"
