#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_path_map.sh"
args=()
for a in "$@"; do
  case "$a" in
    "/home/${SHADOW_LOGIN_USER:-}/Documents/QGroundControl")
      if [[ -n "${SHADOW_WORKSPACE:-}" ]]; then
        args+=("${SHADOW_WORKSPACE}/home/${SHADOW_LOGIN_USER}/Documents/QGroundControl")
      else
        args+=("$a")
      fi
      ;;
    /var/log/qgc) args+=("/shadow/base/var/log/qgc") ;;
    /var/log/mavproxy) args+=("/shadow/base/var/log/mavproxy") ;;
    *) args+=("$(map_shadow_path "$a")") ;;
  esac
done

exec /usr/bin/find "${args[@]}"
