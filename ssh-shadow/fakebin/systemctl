#!/usr/bin/env bash
if [[ "${1:-}" == "status" && "${2:-}" == "qgc.service" ]]; then
  cat <<TXT
● qgc.service - QGroundControl Service
     Loaded: loaded (/etc/systemd/system/qgc.service; enabled)
     Active: active (running) since $(date -u '+%a %Y-%m-%d %H:%M:%S UTC'); 12min ago
   Main PID: 4242 (QGroundControl)
