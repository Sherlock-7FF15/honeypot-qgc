  exit 0
fi
if [[ "${1:-}" == "status" && "${2:-}" == "mavproxy.service" ]]; then
  cat <<TXT
● mavproxy.service - MAVProxy Service
     Loaded: loaded (/etc/systemd/system/mavproxy.service; enabled)
     Active: active (running) since $(date -u '+%a %Y-%m-%d %H:%M:%S UTC'); 12min ago
